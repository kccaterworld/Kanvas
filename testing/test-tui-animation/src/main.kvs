import kanvas.tui;

// Spinner and bouncing ball animation to verify the draw loop runs at the set frameRate.

int ballX = 4;
int ballY = 4;
int velX = 1;
int velY = 1;
int spinnerFrame = 0;
char[] spinnerChars = { '|', '/', '-', '\\' };

void setup() {
    setTitle("Kanvas TUI - Animation Test");
    frameRate(12);
    ballX = cols / 2;
    ballY = rows / 2;
}

void draw() {
    clear();

    setColor(6, 0);
    text(2, 1, "TUI Animation Test — frame: " + frameCount + "  Ctrl+C to exit");

    setColor(2, 0);
    box(1, 2, cols - 2, rows - 4);

    ballX = ballX + velX;
    ballY = ballY + velY;
    if (ballX <= 2 || ballX >= cols - 2) velX = -velX;
    if (ballY <= 3 || ballY >= rows - 3) velY = -velY;

    setColor(11, 0);
    text(ballX, ballY, 'O');

    spinnerFrame = (spinnerFrame + 1) % 4;
    setColor(14, 0);
    text(cols - 4, 1, spinnerChars[spinnerFrame]);

    setColor(8, 0);
    text(2, rows - 2, "frameRate: 12 fps");
}

import kanvas.tui;

int cursorX = 10;
int cursorY = 10;
String lastKey = "none";
int keyCount = 0;

void setup() {
    setTitle("Kanvas TUI - Input Test");
    frameRate(30);
}

void draw() {
    clear();

    setColor(6, 0);
    text(2, 1, "TUI Input Test — use arrow keys to move cursor, Ctrl+C to exit");

    setColor(7, 0);
    text(2, 3, "Last key:  " + lastKey);
    text(2, 4, "Key count: " + keyCount);
    text(2, 5, "Cursor:    (" + cursorX + ", " + cursorY + ")");

    setColor(11, 0);
    box(2, 7, cols - 4, rows - 10);

    setColor(14, 0);
    if (cursorX >= 3 && cursorX < cols - 2 && cursorY >= 8 && cursorY < rows - 3) {
        text(cursorX, cursorY, '@');
    }

    setColor(8, 0);
    text(2, rows - 2, "Arrows: move  W/A/S/D: also move  Ctrl+C: quit");
}

void keyPressed(KeyEvent event) {
    lastKey = event.name();
    keyCount = keyCount + 1;

    if (event.name().equals("UP")    || event.name().equals("w")) cursorY = cursorY - 1;
    if (event.name().equals("DOWN")  || event.name().equals("s")) cursorY = cursorY + 1;
    if (event.name().equals("LEFT")  || event.name().equals("a")) cursorX = cursorX - 1;
    if (event.name().equals("RIGHT") || event.name().equals("d")) cursorX = cursorX + 1;

    if (cursorX < 3)       cursorX = 3;
    if (cursorX > cols - 3) cursorX = cols - 3;
    if (cursorY < 8)       cursorY = 8;
    if (cursorY > rows - 4) cursorY = rows - 4;
}
